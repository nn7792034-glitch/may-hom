<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
<meta charset="UTF-8">
<title>لوحة الأدمن</title>

<style>

<body}
margin:0;
font-family:Tahoma;
background:#111;
color:white;
}

.header{
background:#1e3c72;
padding:20px;
text-align:center;
font-size:30px;
}

.box{
background:#222;
margin:20px;
padding:20px;
border-radius:15px;
}

button{
padding:10px 20px;
border:none;
border-radius:10px;
background:#00bfff;
color:white;
font-size:18px;
cursor:pointer;
}

</style>

</head>

<script>

function checkPassword(){

let password = prompt("أدخل كلمة سر الأدمن");

if(password !== "1234"){

alert("كلمة السر غير صحيحة");

window.location.href="index.html";

}

}

</script>

<div class="header">
لوحة تحكم الأدمن
</div>

<div class="box">

<h2>عدد المستخدمين</h2>

<p>0 مستخدم</p>

<button>إدارة المستخدمين</button>

</div>

<div class="box">

<h2>الباقات</h2>

<p>إدارة الاشتراكات والباقات</p>

<button>إدارة الباقات</button>

</div>

<div class="box">

<h2>الدعوات</h2>

<p>إدارة روابط الدعوة</p>

<button>إدارة الدعوات</button>

</div>

<script>

function checkPassword(){

let password = prompt("أدخل كلمة سر الأدمن");

if(password !== "1234"){

alert("كلمة السر غير صحيحة");

window.location.href="index.html";

}

}

</script>
</html>
